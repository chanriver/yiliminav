# MiniMax API Key
# Get from https://platform.minimax.io/
MINIMAX_API_KEY=your_minimax_api_key_here

# Cloudflare KV Namespace IDs (for quote and poem caching)
QUOTE_KV_NAMESPACE_ID=your_quote_kv_id
POEM_KV_NAMESPACE_ID=your_poem_kv_id

# Cloudflare R2 Bucket Name (for AI covers)
AI_COVERS_BUCKET=ai-covers

# Cloudflare D1 Database (optional)
# D1_DATABASE_ID=your_d1_database_id
